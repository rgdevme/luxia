{
  "name": "@luxia/domain-mcp",
  "version": "0.0.6",
  "description": "Agnos MCP servers domain plugin",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=24"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rgdevme/luxia.git",
    "directory": "packages/domain-mcp"
  },
  "bugs": "https://github.com/rgdevme/luxia/issues",
  "homepage": "https://github.com/rgdevme/luxia#readme",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "agnos": {
    "type": "domain",
    "id": "mcp"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint ."
  },
  "dependencies": {
    "@inquirer/prompts": "^7.2.1",
    "zod": "^3.24.1"
  },
  "peerDependencies": {
    "@luxia/core": "workspace:*"
  },
  "devDependencies": {
    "@luxia/core": "workspace:*",
    "@types/node": "^22.10.5",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3"
  }
}
