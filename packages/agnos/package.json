{
  "name": "@luxia/agnos",
  "version": "0.0.5",
  "description": "Agent-agnostic project configuration manager (CLI + default plugins)",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=24"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rgdevme/luxia.git",
    "directory": "packages/agnos"
  },
  "bugs": "https://github.com/rgdevme/luxia/issues",
  "homepage": "https://github.com/rgdevme/luxia#readme",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "bin": {
    "agnos": "./bin/agnos.js"
  },
  "files": [
    "bin",
    "README.md"
  ],
  "scripts": {
    "build": "node ./scripts/check-versions.mjs",
    "dev": "node ./scripts/check-versions.mjs",
    "typecheck": "node ./scripts/check-versions.mjs",
    "prepublishOnly": "node ./scripts/check-versions.mjs"
  },
  "dependencies": {
    "@luxia/core": "workspace:*",
    "@luxia/agent-claude-code": "workspace:*",
    "@luxia/agent-codex": "workspace:*",
    "@luxia/domain-rules": "workspace:*",
    "@luxia/domain-mcp": "workspace:*",
    "@luxia/domain-skills": "workspace:*",
    "@luxia/domain-docs": "workspace:*"
  }
}
