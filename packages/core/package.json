{
  "name": "@luxia/core",
  "version": "0.0.6",
  "description": "Agnos core CLI and plugin framework",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=24"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rgdevme/luxia.git",
    "directory": "packages/core"
  },
  "bugs": "https://github.com/rgdevme/luxia/issues",
  "homepage": "https://github.com/rgdevme/luxia#readme",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "bin": {
    "agnos": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./fs": {
      "types": "./dist/fs/index.d.ts",
      "default": "./dist/fs/index.js"
    },
    "./cli.js": {
      "default": "./dist/cli.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.2.1",
    "@luxia/domain-rules": "workspace:*",
    "giget": "^1.2.3",
    "minimist": "^1.2.8",
    "picomatch": "^4.0.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/minimist": "^1.2.5",
    "@types/node": "^22.10.5",
    "@types/picomatch": "^3.0.1",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3"
  }
}
