{
  "name": "@agnos/domain-docs",
  "version": "0.0.1",
  "description": "Agnos docs domain plugin",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=24"
  },
  "agnos": {
    "type": "domain",
    "id": "docs"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "chokidar": "^4.0.1",
    "gray-matter": "^4.0.3",
    "zod": "^3.24.1"
  },
  "peerDependencies": {
    "@agnos/core": "workspace:*"
  },
  "devDependencies": {
    "@agnos/core": "workspace:*",
    "@types/node": "^22.10.5",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3"
  }
}
